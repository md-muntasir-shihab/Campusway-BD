{
  "name": "campusway",
  "version": "1.0.0",
  "private": true,
  "description": "CampusWay monorepo root — husky pre-commit hooks",
  "scripts": {
    "prepare": "husky",
    "dev:be": "bash scripts/dev.sh start:be",
    "dev:fe": "bash scripts/dev.sh start:fe",
    "build": "bash scripts/dev.sh build",
    "build:be": "bash scripts/dev.sh build:be",
    "build:fe": "bash scripts/dev.sh build:fe",
    "lint:backend": "cd backend && npx eslint . --ext .ts",
    "lint:frontend": "cd frontend && npx eslint .",
    "typecheck": "bash scripts/dev.sh typecheck",
    "typecheck:backend": "cd backend && npx tsc --noEmit",
    "typecheck:frontend": "cd frontend && npx tsc --noEmit",
    "test": "bash scripts/dev.sh test",
    "test:be": "bash scripts/dev.sh test:be",
    "test:fe": "bash scripts/dev.sh test:fe",
    "seed": "bash scripts/dev.sh seed",
    "seed:exam": "bash scripts/dev.sh seed:exam",
    "clean": "bash scripts/dev.sh clean",
    "check": "bash scripts/dev.sh check",
    "precommit": "npm run lint:backend && npm run lint:frontend && npm run typecheck:backend && npm run typecheck:frontend"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "vite": "^8.0.10"
  }
}
